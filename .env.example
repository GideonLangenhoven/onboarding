# ─── Supabase ───────────────────────────────────────────────────────────
# Copy from Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER ONLY — never expose in client code. Used by /api/onboarding route.
SUPABASE_SERVICE_ROLE_KEY=

# Legacy aliases used by some server-side imports. Mirror the values above.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ─── Notifications ──────────────────────────────────────────────────────
# Optional: notify super admin when new client onboards
RESEND_API_KEY=
SUPER_ADMIN_EMAIL=

# ─── Live credential wiring on onboarding submit ────────────────────────
# REQUIRED for wiring operator credentials live on submit.
# Must exactly match the value used by the admin app and Supabase edge-function secrets.
# Minimum 32 chars. Onboarding calls set_wa_credentials / set_yoco_credentials RPCs with
# this so the keys the operator enters on the Payments & Chat step are encrypted into
# businesses.wa_token_encrypted / yoco_secret_key_encrypted etc. — so WhatsApp and Yoco
# work on day 1 without the operator having to re-enter everything in Settings.
SETTINGS_ENCRYPTION_KEY=

# Admin dashboard URL used in the welcome email sent to the new operator.
# e.g. https://admin.bookingtours.co.za
ADMIN_DASHBOARD_URL=
